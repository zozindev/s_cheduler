# Gmail SMTP settings
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_app_password_here

# MS Teams / Power Automate Webhook
TEAMS_WEBHOOK_URL=https://default.example.environment.api.powerplatform.com/powerautomate/...

# Set to false only when your company network uses SSL inspection and Python
# cannot verify the intercepted certificate chain.
TEAMS_VERIFY_SSL=true

# Optional: use these only when the Power Automate trigger requires OAuth.
# If your trigger is set to "Anyone", leave these blank.
TEAMS_OAUTH_TENANT_ID=
TEAMS_OAUTH_CLIENT_ID=
TEAMS_OAUTH_CLIENT_SECRET=
TEAMS_OAUTH_SCOPE=https://service.flow.microsoft.com/.default

# General settings
LOG_LEVEL=INFO
